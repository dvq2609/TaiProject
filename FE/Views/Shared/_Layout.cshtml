<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VƯƠN</title>
    <link rel="stylesheet" href="~/assets/style.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (ViewData["HideHeaderFooter"] == null || !(bool)ViewData["HideHeaderFooter"]!)
    {
        <header id="site-header"></header>
    }

    <main>
        @RenderBody()
    </main>

    @if (ViewData["HideHeaderFooter"] == null || !(bool)ViewData["HideHeaderFooter"]!)
    {
        <div id="mobile-nav"></div>
        <footer id="site-footer"></footer>
    }

    <script src="~/assets/common.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
