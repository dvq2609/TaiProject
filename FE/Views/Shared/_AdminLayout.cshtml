@{
    var path = Context.Request.Path.ToString().ToLower();
    string ActiveClass(string pageName) {
        if (pageName == "index" && (path == "/admin" || path == "/admin/" || path == "/admin/index" || path == "/admin/index")) {
            return "style=\"background:#16a34a;color:#fff;\"";
        }
        if (pageName != "index" && path.Contains(pageName.ToLower())) {
            return "style=\"background:#16a34a;color:#fff;\"";
        }
        return "style=\"color:#d1fae5;\"";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VƯƠN Admin</title>
    <link rel="stylesheet" href="~/assets/style.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        body { background: #f3f4f6; }
        .admin-layout { display: flex; min-height: 100vh; }
        .main-panel { flex: 1; padding: 2rem; overflow-x: hidden; }
        .admin-nav-link { display: flex; align-items: center; gap: .75rem; padding: .6rem 1.25rem; text-decoration: none; border-radius: .375rem; margin: 0 .5rem .25rem; font-size: .875rem; transition: background 0.2s, color 0.2s; }
        .admin-nav-link:hover { background: rgba(22, 163, 74, 0.1); color: #fff; }
    </style>
</head>
<body>
    <div class="admin-layout">
        <!-- Sidebar -->
        <div id="admin-sidebar-inner" style="width:220px;background:#111827;min-height:100vh;padding:1.5rem 0;flex-shrink:0;display:flex;flex-direction:column;">
            <div style="padding:0 1.25rem 1.5rem;border-bottom:1px solid #1f2937;">
                <div style="display:flex;align-items:center;gap:.5rem;">
                    <div style="width:32px;height:32px;background:#16a34a;border-radius:.5rem;display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;">V</div>
                    <span style="font-weight:700;color:#fff;">VƯƠN Admin</span>
                </div>
            </div>
            <nav style="padding:1rem 0;flex:1;">
                <p style="font-size:.65rem;font-weight:600;color:#6b7280;text-transform:uppercase;padding:.25rem 1.25rem;margin-bottom:.25rem;">Tổng quan</p>
                <a href="/admin/index" class="admin-nav-link" @Html.Raw(ActiveClass("index"))>📊 Dashboard</a>
                
                <p style="font-size:.65rem;font-weight:600;color:#6b7280;text-transform:uppercase;padding:.25rem 1.25rem;margin:.75rem 0 .25rem;">Quản lý</p>
                <a href="/admin/products" class="admin-nav-link" @Html.Raw(ActiveClass("products"))>📦 Sản phẩm</a>
                <a href="/admin/categories" class="admin-nav-link" @Html.Raw(ActiveClass("categories"))>📁 Danh mục</a>
                <a href="/admin/inventory" class="admin-nav-link" @Html.Raw(ActiveClass("inventory"))>🏭 Kho hàng</a>
                <a href="/admin/orders" class="admin-nav-link" @Html.Raw(ActiveClass("orders"))>🛒 Đơn hàng</a>
                <a href="/admin/customers" class="admin-nav-link" @Html.Raw(ActiveClass("customers"))>👥 Khách hàng</a>
                
                <p style="font-size:.65rem;font-weight:600;color:#6b7280;text-transform:uppercase;padding:.25rem 1.25rem;margin:.75rem 0 .25rem;">Nội dung</p>
                <a href="/admin/ai" class="admin-nav-link" @Html.Raw(ActiveClass("ai"))>🤖 AI & Dữ liệu</a>
                <a href="/admin/faq" class="admin-nav-link" @Html.Raw(ActiveClass("faq"))>❓ FAQ</a>
                <a href="/admin/promotions" class="admin-nav-link" @Html.Raw(ActiveClass("promotions"))>🎁 Khuyến mãi</a>
            </nav>
            <div style="padding:1.25rem;border-top:1px solid #1f2937;margin-top:auto;">
                <a href="/" style="display:flex;align-items:center;gap:.5rem;color:#9ca3af;text-decoration:none;font-size:.8rem;margin-bottom:.75rem;">&larr; Về trang chủ</a>
                <button onclick="doLogout()" style="width:100%;padding:.5rem;background:#1f2937;color:#9ca3af;border:none;border-radius:.375rem;cursor:pointer;font-size:.8rem;">🚪 Đăng xuất</button>
            </div>
        </div>

        <!-- Main Panel -->
        <div class="main-panel" style="display:flex;flex-direction:column;">
            <!-- Admin Top Header -->
            <div id="admin-top-header" style="background:#fff;border-bottom:1px solid #e5e7eb;padding:.75rem 2rem;display:flex;align-items:center;justify-content:flex-end;gap:1rem;position:sticky;top:0;z-index:50;margin:-2rem -2rem 1.5rem -2rem;">
                <div style="position:relative;" id="admin-search-wrap">
                    <div style="display:flex;align-items:center;background:#f3f4f6;border:1.5px solid transparent;border-radius:9999px;padding:0 .875rem;gap:.4rem;width:260px;transition:all .2s;" id="admin-search-box">
                        <svg width="16" height="16" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <input type="text" id="admin-search-input" placeholder="Tìm sản phẩm..." autocomplete="off"
                            style="border:none;outline:none;background:transparent;font-size:.875rem;color:#111827;width:100%;padding:.45rem 0;"
                            onfocus="this.closest('#admin-search-box').style.cssText='display:flex;align-items:center;background:#fff;border:1.5px solid #22c55e;border-radius:9999px;padding:0 .875rem;gap:.4rem;width:300px;box-shadow:0 0 0 3px rgba(22,163,74,.1);transition:all .2s;'"
                            onblur="this.closest('#admin-search-box').style.cssText='display:flex;align-items:center;background:#f3f4f6;border:1.5px solid transparent;border-radius:9999px;padding:0 .875rem;gap:.4rem;width:260px;transition:all .2s;'">
                        <button id="admin-search-clear" onclick="clearAdminSearch()" style="background:none;border:none;cursor:pointer;color:#9ca3af;padding:0;display:none;align-items:center;" title="Xóa">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:.5rem;">
                    <div style="width:32px;height:32px;background:#16a34a;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:.875rem;">A</div>
                    <span style="font-size:.875rem;color:#374151;font-weight:500;">Admin</span>
                </div>
            </div>
            @RenderBody()
        </div>
    </div>

    <script src="~/assets/common.js" asp-append-version="true"></script>
    <script>
        (function() {
            const user = Store.getUser();
            if (!user || !user.role || user.role.toLowerCase() !== 'admin') {
                window.location.href = '/login';
            }
        })();

        // ── Admin Header Search ─────────────────────────
        (function initAdminSearch() {
            const input = document.getElementById('admin-search-input');
            const clearBtn = document.getElementById('admin-search-clear');
            if (!input) return;

            let timer = null;

            // Pre-fill from URL if navigated here with search param
            const urlSearch = new URLSearchParams(window.location.search).get('search');
            if (urlSearch) {
                input.value = urlSearch;
                if (clearBtn) clearBtn.style.display = 'flex';
            }

            input.addEventListener('input', function() {
                const q = this.value.trim();
                if (clearBtn) clearBtn.style.display = q ? 'flex' : 'none';
                clearTimeout(timer);
                timer = setTimeout(() => {
                    const isProductsPage = window.location.pathname.toLowerCase().includes('/admin/products') &&
                        !window.location.pathname.toLowerCase().includes('product-form');
                    if (isProductsPage && typeof onSearchChange === 'function') {
                        // Sync to the page's built-in search input and trigger it
                        const pageInput = document.getElementById('search-prod');
                        if (pageInput) { pageInput.value = q; onSearchChange(); }
                    } else if (q) {
                        window.location.href = '/admin/products?search=' + encodeURIComponent(q);
                    }
                }, 300);
            });

            input.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    const q = this.value.trim();
                    clearTimeout(timer);
                    if (q) window.location.href = '/admin/products?search=' + encodeURIComponent(q);
                }
            });
        })();

        function clearAdminSearch() {
            const input = document.getElementById('admin-search-input');
            const clearBtn = document.getElementById('admin-search-clear');
            if (input) input.value = '';
            if (clearBtn) clearBtn.style.display = 'none';
            // If on products page, reset search
            const pageInput = document.getElementById('search-prod');
            if (pageInput) { pageInput.value = ''; if(typeof onSearchChange === 'function') onSearchChange(); }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
