@{
    ViewData["Title"] = "Đổi mật khẩu";
}

@section Styles {
    <style>
        .pw-input-wrap { position:relative; }
        .pw-toggle { position:absolute; right:.75rem; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:#9ca3af; }
        .strength-bar { height:4px; border-radius:2px; margin-top:.25rem; transition:all .3s; }
    </style>
}

<div class="page-content" style="max-width:450px;">
    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem;">
        <a href="profile" style="text-decoration:none;color:#6b7280;font-size:1.25rem;">‹</a>
        <h1 style="font-size:1.5rem;font-weight:700;">Đổi mật khẩu</h1>
    </div>

    <div class="card card-pad">
        <div class="form-group">
            <label>Mật khẩu hiện tại</label>
            <div class="pw-input-wrap">
                <input type="password" id="current-pw" class="form-control" placeholder="Nhập mật khẩu hiện tại">
                <button class="pw-toggle" onclick="togglePw('current-pw')">👁</button>
            </div>
        </div>
        <div class="form-group">
            <label>Mật khẩu mới</label>
            <div class="pw-input-wrap">
                <input type="password" id="new-pw" class="form-control" placeholder="Tối thiểu 6 ký tự" oninput="checkStrength(this.value)">
                <button class="pw-toggle" onclick="togglePw('new-pw')">👁</button>
            </div>
            <div class="strength-bar" id="strength-bar" style="width:0;background:#e5e7eb;"></div>
            <small id="strength-text" style="color:#9ca3af;font-size:.75rem;"></small>
        </div>
        <div class="form-group">
            <label>Xác nhận mật khẩu mới</label>
            <div class="pw-input-wrap">
                <input type="password" id="confirm-pw" class="form-control" placeholder="Nhập lại mật khẩu mới">
                <button class="pw-toggle" onclick="togglePw('confirm-pw')">👁</button>
            </div>
        </div>
        <div id="err-msg" class="alert alert-error" style="display:none;"></div>
        <button onclick="changePassword()" class="btn btn-green btn-full">Đổi mật khẩu</button>
    </div>

    <div class="alert alert-info" style="margin-top:1rem;">
        🔐 Mật khẩu tốt nên có nhất 8 ký tự, bao gồm chữ hoa, số và ký tự đặc biệt
    </div>
</div>

@section Scripts {
    <script>
        requireAuth();

        function togglePw(id) {
            const inp = document.getElementById(id);
            inp.type = inp.type==='password' ? 'text' : 'password';
        }

        function checkStrength(val) {
            const bar = document.getElementById('strength-bar');
            const txt = document.getElementById('strength-text');
            if(!val) { bar.style.width='0'; txt.textContent=''; return; }
            let score = 0;
            if(val.length>=6) score++;
            if(val.length>=8) score++;
            if(/[A-Z]/.test(val)) score++;
            if(/[0-9]/.test(val)) score++;
            if(/[^A-Za-z0-9]/.test(val)) score++;
            const levels = [
                [0,'0','','#e5e7eb'],
                [1,'20%','Rất yếu','#ef4444'],
                [2,'40%','Yếu','#f97316'],
                [3,'60%','Trung bình','#f59e0b'],
                [4,'80%','Mạnh','#84cc16'],
                [5,'100%','Rất mạnh','#16a34a']
            ];
            const [,w,label,color] = levels[score]||levels[4];
            bar.style.width=w; bar.style.background=color; txt.textContent=label; txt.style.color=color;
        }

        function changePassword() {
            const cur=document.getElementById('current-pw').value;
            const nw=document.getElementById('new-pw').value;
            const cf=document.getElementById('confirm-pw').value;
            const err=document.getElementById('err-msg');
            err.style.display='none';

            if(!cur) { err.style.display='block'; err.textContent='Nhập mật khẩu hiện tại'; return; }
            if(nw.length<6) { err.style.display='block'; err.textContent='Mật khẩu mới phải có ít nhất 6 ký tự'; return; }
            if(nw!==cf) { err.style.display='block'; err.textContent='Mật khẩu xác nhận không khớp'; return; }
            // Mock: accept any current password
            showToast('Đổi mật khẩu thành công!');
            setTimeout(()=>location.href='profile', 1200);
        }
    </script>
}
