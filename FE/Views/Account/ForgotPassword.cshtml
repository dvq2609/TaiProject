@{
    ViewData["Title"] = "Quên mật khẩu";
    ViewData["HideHeaderFooter"] = true;
}

@section Styles {
    <style>body { background: #f9fafb; }</style>
}

<div class="auth-page">
    <div class="auth-card">
        <a href="login" style="display:inline-flex;align-items:center;gap:.5rem;color:#6b7280;font-size:.875rem;margin-bottom:1.5rem;">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Quay lại
        </a>
        <div class="auth-icon green-light" style="width:64px;height:64px;">
            <svg width="32" height="32" fill="none" stroke="#16a34a" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h1 style="text-align:center;font-size:1.5rem;font-weight:700;margin-bottom:.25rem;">Quên mật khẩu</h1>
        <p style="text-align:center;color:#6b7280;margin-bottom:1.5rem;">Nhập email để nhận mã xác thực</p>

        <form id="forgot-form">
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="email" class="form-control" placeholder="email@example.com" required>
            </div>
            <button type="submit" class="btn btn-green btn-full">Gửi mã OTP</button>
        </form>

        <div class="alert alert-info" style="margin-top:1.5rem;">
            💡 Mã OTP sẽ được gửi đến email của bạn trong vòng 1–2 phút
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('forgot-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            const email = document.getElementById('email').value.trim();
            if (!email) { showToast('Vui lòng nhập email', 'error'); return; }
            const btn = e.target.querySelector('button[type=submit]');
            btn.textContent = 'Đang gửi...'; btn.disabled = true;

            const result = await API.forgotPassword(email);
            btn.textContent = 'Gửi mã OTP'; btn.disabled = false;

            if (result.ok) {
                sessionStorage.setItem('pending_email', email);
                sessionStorage.setItem('otp_type', 'reset');
                showToast('Đã gửi mã OTP về email!');
                setTimeout(() => { window.location.href = 'verify-otp'; }, 1200);
            } else {
                showToast(result.error || 'Gửi OTP thất bại', 'error');
            }
        });
    </script>
}
