@{
    ViewData["Title"] = "Đăng ký";
    ViewData["HideHeaderFooter"] = true;
}

@section Styles {
    <style>body { background: #f9fafb; }</style>
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-icon green" style="width:64px;height:64px;">
            <svg width="32" height="32" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        </div>
        <h1 style="text-align:center;font-size:1.5rem;font-weight:700;margin-bottom:.25rem;">Đăng ký tài khoản</h1>
        <p style="text-align:center;color:#6b7280;margin-bottom:1.5rem;">Tạo tài khoản để bắt đầu trồng cây</p>

        <div id="error-msg" class="alert alert-error" style="display:none"></div>

        <form id="register-form">
            <div class="form-group">
                <label>Họ và tên</label>
                <div class="input-wrap">
                    <span class="icon" style="top:50%;transform:translateY(-50%)">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </span>
                    <input type="text" id="fullName" class="form-control has-icon" placeholder="Nguyễn Văn A" required>
                </div>
            </div>
            <div class="form-group">
                <label>Email</label>
                <div class="input-wrap">
                    <span class="icon" style="top:50%;transform:translateY(-50%)">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </span>
                    <input type="email" id="email" class="form-control has-icon" placeholder="email@example.com" required>
                </div>
            </div>
            <div class="form-group">
                <label>Số điện thoại</label>
                <div class="input-wrap">
                    <span class="icon" style="top:50%;transform:translateY(-50%)">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.79 19.79 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
                    </span>
                    <input type="tel" id="phone" class="form-control has-icon" placeholder="0901234567" required>
                </div>
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <div class="input-wrap">
                    <span class="icon" style="top:50%;transform:translateY(-50%)">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                    </span>
                    <input type="password" id="password" class="form-control has-icon" placeholder="••••••••" required>
                </div>
            </div>
            <div class="form-group">
                <label>Xác nhận mật khẩu</label>
                <div class="input-wrap">
                    <span class="icon" style="top:50%;transform:translateY(-50%)">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                    </span>
                    <input type="password" id="confirmPassword" class="form-control has-icon" placeholder="••••••••" required>
                </div>
            </div>
            <button type="submit" class="btn btn-green btn-full">Tạo tài khoản</button>
        </form>
        <p style="text-align:center;margin-top:1.5rem;color:#6b7280;font-size:.9rem;">
            Đã có tài khoản? <a href="login" style="color:#16a34a;">Đăng nhập ngay</a>
        </p>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('register-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            // Lấy đúng id="fullName" thay vì id="name" bị lỗi trong static template trước kia
            const name = document.getElementById('fullName') ? document.getElementById('fullName').value.trim() : '';
            const email = document.getElementById('email').value.trim();
            const phone = document.getElementById('phone') ? document.getElementById('phone').value.trim() : '';
            const pwd = document.getElementById('password').value;
            const cpwd = document.getElementById('confirmPassword').value;
            const errEl = document.getElementById('error-msg');
            const btn = e.target.querySelector('button[type=submit]');

            if(pwd !== cpwd) { errEl.textContent = 'Mật khẩu không khớp'; errEl.style.display='block'; return; }
            errEl.style.display='none';
            btn.textContent = 'Đang đăng ký...'; btn.disabled = true;

            const result = await API.register(name || email.split('@@')[0], email, pwd, phone);
            btn.textContent = 'Tạo tài khoản'; btn.disabled = false;

            if(result.ok) {
                showToast('Đăng ký thành công! Vui lòng kiểm tra email để xác thực.');
                setTimeout(()=>{ window.location.href='login?status=success&message=' + encodeURIComponent('Đăng ký thành công! Vui lòng kiểm tra email để kích hoạt tài khoản trước khi đăng nhập.'); }, 1500);
            } else {
                errEl.textContent = result.error || 'Đăng ký thất bại, thử lại sau.';
                errEl.style.display='block';
            }
        });
    </script>
}
