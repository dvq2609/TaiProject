@{
    ViewData["Title"] = "Đăng nhập";
    ViewData["HideHeaderFooter"] = true;
}

@section Styles {
    <style>
        body { background: #f9fafb; }
        .google-btn { width:100%; display:flex; align-items:center; justify-content:center; gap:.75rem; padding:.75rem; border:2px solid #d1d5db; border-radius:.5rem; background:#fff; cursor:pointer; font-size:.9rem; color:#374151; transition:background .2s; }
        .google-btn:hover { background:#f9fafb; }
        .google-icon { width:20px; height:20px; }
    </style>
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-icon green" style="width:64px;height:64px;">
            <svg width="32" height="32" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>
        </div>
        <h1 style="text-align:center;font-size:1.5rem;font-weight:700;margin-bottom:.25rem;">Đăng nhập</h1>
        <p style="text-align:center;color:#6b7280;margin-bottom:1.5rem;">Chào mừng trở lại với VƯƠN</p>

        <div id="error-msg" class="alert alert-error" style="display:none"></div>

        <form id="login-form">
            <div class="form-group">
                <label>Email hoặc Số điện thoại</label>
                <div class="input-wrap">
                    <span class="icon" style="top:50%;transform:translateY(-50%)">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </span>
                    <input type="text" id="email" class="form-control has-icon" placeholder="email@example.com hoặc 0901234567" required>
                </div>
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <div class="input-wrap">
                    <span class="icon" style="top:50%;transform:translateY(-50%)">
                        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                    </span>
                    <input type="password" id="password" class="form-control has-icon" placeholder="••••••••" required>
                </div>
            </div>
            <div style="text-align:right;margin-bottom:1rem;">
                <a href="forgot-password" style="font-size:.875rem;color:#16a34a;">Quên mật khẩu?</a>
            </div>
            <button type="submit" class="btn btn-green btn-full">Đăng nhập</button>
        </form>

        <div class="divider-text" style="margin:1.5rem 0;">Hoặc</div>

        <button class="google-btn" onclick="googleLogin()">
            <svg class="google-icon" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Đăng nhập bằng Google
        </button>

        <p style="text-align:center;margin-top:1.5rem;color:#6b7280;font-size:.9rem;">
            Chưa có tài khoản? <a href="register" style="color:#16a34a;">Đăng ký ngay</a>
        </p>

       
    </div>
</div>

@section Scripts {
    <script>
        // Kiểm tra và bắt Token từ URL (sau khi đăng nhập Google thành công và được BE redirect về)
        const token = getParam('token');
        if (token) {
            const email = getParam('email');
            const name = getParam('name');
            const role = getParam('role');
            
            saveToken(token);
            Store.setUser({ id: '0', name: name || 'Google User', email: email, role: role || 'user' });
            
            // Xoá query string để làm sạch URL
            window.history.replaceState({}, document.title, window.location.pathname);
            window.location.href = 'home';
        }

        // Bắt status và message từ URL (khi kích hoạt tài khoản hoặc đăng ký thành công)
        const status = getParam('status');
        const message = getParam('message');
        if (status && message) {
            if (status === 'success') {
                showToast(message, 'success');
            } else {
                const errEl = document.getElementById('error-msg');
                if (errEl) {
                    errEl.textContent = message;
                    errEl.style.display = 'block';
                }
            }
            // Xoá query string để làm sạch URL
            window.history.replaceState({}, document.title, window.location.pathname);
        }

        document.getElementById('login-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const errEl = document.getElementById('error-msg');
            const btn = e.target.querySelector('button[type=submit]');

            if(!email || !password) {
                errEl.textContent = 'Vui lòng nhập đầy đủ thông tin';
                errEl.style.display = 'block'; return;
            }
            errEl.style.display = 'none';
            btn.textContent = 'Đang đăng nhập...'; btn.disabled = true;

            const result = await API.login(email, password);
            btn.textContent = 'Đăng nhập'; btn.disabled = false;

            if(result.ok) {
                const user = Store.getUser();
                window.location.href = (user && user.role && user.role.toLowerCase() === 'admin') ? '/admin/index' : 'home';
            } else {
                errEl.textContent = result.error || 'Email hoặc mật khẩu không đúng';
                errEl.style.display = 'block';
            }
        });

        function googleLogin() {
            // Chuyển hướng trình duyệt đến API đăng nhập Google của Backend một cách động
            window.location.href = API_BASE + '/auth/oauth/google';
        }
    </script>
}
