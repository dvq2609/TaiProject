@{
    ViewData["Title"] = "AI & Dữ liệu";
}

@section Styles {
    <style>
        .ai-card{background:#fff;border-radius:.75rem;padding:1.5rem;box-shadow:0 1px 4px rgba(0,0,0,.07);margin-bottom:1rem;} 
        .q-item{display:flex;align-items:flex-start;gap:.75rem;padding:.75rem;border:1px solid #f3f4f6;border-radius:.5rem;margin-bottom:.5rem;} 
        .q-item:hover{background:#fafafa;}
    </style>
}

<div style="margin-bottom:1.5rem;">
  <h1 style="font-size:1.5rem;font-weight:800;">AI & Dữ liệu</h1>
  <p style="color:#6b7280;font-size:.875rem;">Quản lý dữ liệu huấn luyện AI và câu hỏi thường gặp</p>
</div>

<!-- AI stats -->
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem;margin-bottom:1.5rem;">
  <div class="ai-card" style="text-align:center;padding:1rem;">
    <div style="font-size:2rem;">🤖</div>
    <div style="font-size:1.25rem;font-weight:700;color:#2563eb;">2,847</div>
    <div style="font-size:.75rem;color:#6b7280;">Cuộc hội thoại</div>
  </div>
  <div class="ai-card" style="text-align:center;padding:1rem;">
    <div style="font-size:2rem;">💬</div>
    <div style="font-size:1.25rem;font-weight:700;color:#16a34a;">94%</div>
    <div style="font-size:.75rem;color:#6b7280;">Tỷ lệ hài lòng</div>
  </div>
  <div class="ai-card" style="text-align:center;padding:1rem;">
    <div style="font-size:2rem;">📸</div>
    <div style="font-size:1.25rem;font-weight:700;color:#f59e0b;">312</div>
    <div style="font-size:.75rem;color:#6b7280;">Ảnh chẩn đoán</div>
  </div>
  <div class="ai-card" style="text-align:center;padding:1rem;">
    <div style="font-size:2rem;">⚡</div>
    <div style="font-size:1.25rem;font-weight:700;color:#8b5cf6;">1.2s</div>
    <div style="font-size:.75rem;color:#6b7280;">Thời gian phản hồi</div>
  </div>
</div>

<!-- Quick questions management -->
<div class="ai-card">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
    <h2 style="font-weight:700;">Câu hỏi gợi ý AI Chat</h2>
    <button onclick="addQuestion()" class="btn btn-green btn-sm">+ Thêm câu hỏi</button>
  </div>
  <div id="q-list"></div>
</div>

<!-- Demo responses management -->
<div class="ai-card">
  <h2 style="font-weight:700;margin-bottom:1rem;">Câu trả lời mẫu</h2>
  <p style="font-size:.875rem;color:#6b7280;margin-bottom:1rem;">Dùng khi AI không trả lời được hoặc API bị lỗi</p>
  <div id="demo-list"></div>
</div>

<!-- Training status -->
<div class="ai-card">
  <h2 style="font-weight:700;margin-bottom:1rem;">Trạng thái AI</h2>
  <div style="display:flex;flex-direction:column;gap:.5rem;">
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid #f9fafb;font-size:.875rem;">
      <span style="color:#6b7280;">Model</span>
      <span style="font-weight:600;color:#16a34a;">Gemini 1.5 Flash</span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid #f9fafb;font-size:.875rem;">
      <span style="color:#6b7280;">Trạng thái</span>
      <span style="font-weight:600;color:#16a34a;">Hoạt động tốt</span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid #f9fafb;font-size:.875rem;">
      <span style="color:#6b7280;">API Requests</span>
      <span style="font-weight:600;color:#f59e0b;">2,847/10,000 (tháng)</span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid #f9fafb;font-size:.875rem;">
      <span style="color:#6b7280;">Fallback mode</span>
      <span style="font-weight:600;color:#16a34a;">Sẵn sàng</span>
    </div>
  </div>
  <button onclick="testAI()" class="btn btn-outline btn-sm" style="margin-top:1rem;cursor:pointer;">🧪 Test kết nối AI</button>
  <span id="test-result" style="font-size:.8rem;margin-left:.75rem;"></span>
</div>

@section Scripts {
    <script>
        // Render quick questions
        document.getElementById('q-list').innerHTML = AI_QUESTIONS.map((q,i)=>`
          <div class="q-item">
            <span style="background:#eff6ff;color:#2563eb;border-radius:50%;width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;flex-shrink:0;">${i+1}</span>
            <p style="flex:1;font-size:.875rem;">${q}</p>
            <div style="display:flex;gap:.25rem;">
              <button style="font-size:.75rem;padding:.2rem .5rem;background:none;border:1px solid #e5e7eb;border-radius:.25rem;cursor:pointer;" onclick="editQ(${i},'${q.replace(/'/g,"\\'")}')">Sửa</button>
              <button style="font-size:.75rem;padding:.2rem .5rem;background:none;border:1px solid #fee2e2;color:#ef4444;border-radius:.25rem;cursor:pointer;" onclick="showToast('Đã xóa câu hỏi')">Xóa</button>
            </div>
          </div>`).join('');

        // Demo responses
        document.getElementById('demo-list').innerHTML = Object.entries(DEMO_CHAT_RESPONSES).slice(0,5).map(([k,v])=>`
          <div class="q-item" style="flex-direction:column;gap:.5rem;">
            <div style="display:flex;gap:.5rem;align-items:center;">
              <span style="background:#fef3c7;color:#92400e;padding:.15rem .5rem;border-radius:.25rem;font-size:.75rem;font-weight:600;">${k}</span>
              <span style="font-size:.75rem;color:#9ca3af;">từ khoá kích hoạt</span>
            </div>
            <p style="font-size:.8rem;color:#374151;line-height:1.5;">${v.substring(0,120)}...</p>
          </div>`).join('');

        function addQuestion() {
          const q=prompt('Nhập câu hỏi mới:');
          if(q) showToast('Đã thêm câu hỏi: '+q);
        }
        function editQ(i,q) {
          const nq=prompt('Chỉnh sửa câu hỏi:',q);
          if(nq) showToast('Đã cập nhật câu hỏi');
        }

        async function testAI() {
          const el=document.getElementById('test-result');
          el.textContent='Đang kiểm tra...'; el.style.color='#6b7280';
          const reply=await askGemini('Xin chào, test kết nối');
          el.textContent='✅ AI phản hồi: '+reply.substring(0,50)+'...';
          el.style.color='#16a34a';
        }
    </script>
}
