@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <style>
        .stat-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1.25rem; margin-bottom:2rem; }
        .stat-card { background:#fff; border-radius:1rem; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,.08); border-left:4px solid transparent; transition:transform .2s,box-shadow .2s; }
        .stat-card:hover { transform:translateY(-2px); box-shadow:0 4px 16px rgba(0,0,0,.12); }
        .stat-icon { width:48px; height:48px; border-radius:.75rem; display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin-bottom:.75rem; }
        .stat-label { font-size:.8rem; color:#6b7280; font-weight:500; text-transform:uppercase; letter-spacing:.05em; margin-bottom:.25rem; }
        .stat-value { font-size:2rem; font-weight:800; line-height:1; }
        .stat-sub { font-size:.75rem; color:#9ca3af; margin-top:.5rem; }
        .section-card { background:#fff; border-radius:1rem; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,.08); margin-bottom:1.5rem; }
        .section-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem; }
        .section-title { font-size:1rem; font-weight:700; color:#111827; }
        .data-table { width:100%; border-collapse:collapse; }
        .data-table th { text-align:left; padding:.75rem 1rem; background:#f9fafb; font-size:.75rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em; border-bottom:1px solid #e5e7eb; }
        .data-table td { padding:.75rem 1rem; border-bottom:1px solid #f9fafb; font-size:.875rem; color:#374151; }
        .data-table tr:last-child td { border-bottom:none; }
        .data-table tr:hover td { background:#f9fafb; }
        .badge { display:inline-flex; align-items:center; padding:.25rem .75rem; border-radius:9999px; font-size:.75rem; font-weight:600; }
        .badge-green { background:#d1fae5; color:#065f46; }
        .badge-blue { background:#dbeafe; color:#1e40af; }
        .badge-yellow { background:#fef3c7; color:#92400e; }
        .badge-red { background:#fee2e2; color:#991b1b; }
        .badge-gray { background:#f3f4f6; color:#374151; }
        .loading-row td { text-align:center; padding:2rem; color:#9ca3af; }
        @@media(max-width:768px) { .stat-grid { grid-template-columns:1fr 1fr; } }
        @@media(max-width:480px) { .stat-grid { grid-template-columns:1fr; } }
    </style>
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
  <div>
    <h1 style="font-size:1.5rem;font-weight:800;color:#111827;">Dashboard</h1>
    <p style="color:#6b7280;font-size:.875rem;margin-top:.25rem;">Tổng quan hoạt động kinh doanh</p>
  </div>
  <div style="font-size:.875rem;color:#6b7280;font-weight:500;" id="dash-date"></div>
</div>

<!-- Stats Cards -->
<div class="stat-grid">
  <div class="stat-card" style="border-left-color:#10b981;">
    <div class="stat-icon" style="background:#d1fae5;">💰</div>
    <div class="stat-label">Doanh thu hôm nay</div>
    <div class="stat-value" style="color:#10b981;" id="stat-today-revenue">—</div>
    <div class="stat-sub">Thực thu trong ngày</div>
  </div>
  <div class="stat-card" style="border-left-color:#059669;">
    <div class="stat-icon" style="background:#d1fae5;">📈</div>
    <div class="stat-label">Doanh thu tháng này</div>
    <div class="stat-value" style="color:#059669;" id="stat-month-revenue">—</div>
    <div class="stat-sub">Tích lũy từ đầu tháng</div>
  </div>
  <div class="stat-card" style="border-left-color:#8b5cf6;">
    <div class="stat-icon" style="background:#ede9fe;">👤</div>
    <div class="stat-label">Lượng khách hàng</div>
    <div class="stat-value" style="color:#8b5cf6;" id="stat-customer-count">—</div>
    <div class="stat-sub">Tài khoản khách hàng</div>
  </div>
  <div class="stat-card" style="border-left-color:#2563eb;">
    <div class="stat-icon" style="background:#dbeafe;">✅</div>
    <div class="stat-label">Đơn đặt thành công</div>
    <div class="stat-value" style="color:#2563eb;" id="stat-orders-count">—</div>
    <div class="stat-sub">Đơn đã thanh toán</div>
  </div>
</div>

<!-- Products Table -->
<div class="section-card">
  <div class="section-header">
    <span class="section-title">🌱 Danh mục sản phẩm</span>
    <a href="products" style="font-size:.8rem;color:#2563eb;text-decoration:none;font-weight:500;">Quản lý sản phẩm →</a>
  </div>
  <div style="overflow-x:auto;">
    <table class="data-table" id="products-table">
      <thead><tr>
        <th>Tên sản phẩm</th>
        <th>Danh mục</th>
        <th>Giá</th>
        <th>Tồn kho</th>
        <th>Trạng thái</th>
      </tr></thead>
      <tbody id="products-tbody">
        <tr class="loading-row"><td colspan="5">Đang tải...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Orders Table -->
<div class="section-card">
  <div class="section-header">
    <span class="section-title">📦 Đơn hàng gần đây</span>
    <a href="orders" style="font-size:.8rem;color:#2563eb;text-decoration:none;font-weight:500;">Xem tất cả →</a>
  </div>
  <div style="overflow-x:auto;">
    <table class="data-table" id="orders-table">
      <thead><tr>
        <th>Mã đơn</th>
        <th>Khách hàng</th>
        <th>Tổng tiền</th>
        <th>Trạng thái</th>
        <th>Ngày đặt</th>
      </tr></thead>
      <tbody id="orders-tbody">
        <tr class="loading-row"><td colspan="5">Đang tải...</td></tr>
      </tbody>
    </table>
  </div>
</div>

@section Scripts {
    <script>
        // Format tiền VND
        function fmt(n) {
            if (!n && n !== 0) return '0đ';
            return Number(n).toLocaleString('vi-VN') + 'đ';
        }

        // Badge trạng thái đơn hàng
        function orderBadge(status) {
            const s = (status || '').toLowerCase();
            if (s === 'completed' || s === 'delivered') return `<span class="badge badge-green">Hoàn thành</span>`;
            if (s === 'processing') return `<span class="badge badge-blue">Đang xử lý</span>`;
            if (s === 'shipping' || s === 'shipped') return `<span class="badge badge-yellow">Đang giao</span>`;
            if (s === 'cancelled' || s === 'canceled') return `<span class="badge badge-red">Đã hủy</span>`;
            if (s === 'pending') return `<span class="badge badge-yellow">Chờ xác nhận</span>`;
            return `<span class="badge badge-gray">${status}</span>`;
        }

        // Badge tồn kho
        function stockBadge(stock, inStock) {
            if (!inStock || stock === 0) return `<span class="badge badge-red">Hết hàng</span>`;
            if (stock <= 5) return `<span class="badge badge-yellow">Còn ${stock}</span>`;
            return `<span class="badge badge-green">Còn ${stock}</span>`;
        }

        // Load thống kê từ API
        async function loadStats() {
            try {
                const res = await fetch('http://localhost:5172/api/admin/dashboard/stats', {
                    headers: { 'Authorization': 'Bearer ' + (localStorage.getItem('vuon_token') || '') }
                });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const stats = await res.json();

                const todayRev = stats.todayRevenue ?? stats.TodayRevenue ?? 0;
                const monthRev = stats.monthRevenue ?? stats.MonthRevenue ?? 0;
                const custCount = stats.customerCount ?? stats.CustomerCount ?? 0;
                const ordCount = stats.successfulOrderCount ?? stats.SuccessfulOrderCount ?? 0;

                document.getElementById('stat-today-revenue').textContent = fmt(todayRev);
                document.getElementById('stat-month-revenue').textContent = fmt(monthRev);
                document.getElementById('stat-customer-count').textContent = custCount.toLocaleString('vi-VN');
                document.getElementById('stat-orders-count').textContent = ordCount.toLocaleString('vi-VN');
            } catch (e) {
                console.error('Lỗi tải stats:', e);
                document.getElementById('stat-today-revenue').textContent = 'Lỗi';
                document.getElementById('stat-month-revenue').textContent = 'Lỗi';
                document.getElementById('stat-customer-count').textContent = 'Lỗi';
                document.getElementById('stat-orders-count').textContent = 'Lỗi';
            }
        }

        // Load danh sách sản phẩm từ API
        async function loadProducts() {
            const tbody = document.getElementById('products-tbody');
            try {
                const res = await fetch('http://localhost:5172/api/products', {
                    headers: { 'Authorization': 'Bearer ' + (localStorage.getItem('vuon_token') || '') }
                });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const data = await res.json();

                // Hỗ trợ cả hai format: array trực tiếp hoặc { items: [] }
                const products = Array.isArray(data) ? data : (data.items || data.Items || data.products || data.Products || []);

                if (products.length === 0) {
                    tbody.innerHTML = '<tr class="loading-row"><td colspan="5">Chưa có sản phẩm nào.</td></tr>';
                    return;
                }

                tbody.innerHTML = products.slice(0, 10).map(p => {
                    const name = p.name || p.Name || 'N/A';
                    const category = p.categoryName || p.CategoryName || p.category || 'N/A';
                    const price = p.price || p.Price || 0;
                    const stock = p.stock ?? p.Stock ?? p.stockQuantity ?? p.StockQuantity ?? 0;
                    const inStock = p.inStock ?? p.InStock ?? p.isAvailable ?? p.IsAvailable ?? (stock > 0);
                    return `<tr>
                        <td style="font-weight:600;">${name}</td>
                        <td><span class="badge badge-blue">${category}</span></td>
                        <td style="font-weight:600;color:#059669;">${fmt(price)}</td>
                        <td>${stockBadge(stock, inStock)}</td>
                        <td>${inStock ? '<span class="badge badge-green">Đang bán</span>' : '<span class="badge badge-red">Tạm dừng</span>'}</td>
                    </tr>`;
                }).join('');
            } catch (e) {
                console.error('Lỗi tải sản phẩm:', e);
                tbody.innerHTML = `<tr class="loading-row"><td colspan="5" style="color:#ef4444;">Lỗi tải sản phẩm: ${e.message}</td></tr>`;
            }
        }

        // Load đơn hàng từ API
        async function loadOrders() {
            const tbody = document.getElementById('orders-tbody');
            try {
                const res = await fetch('http://localhost:5172/api/orders', {
                    headers: { 'Authorization': 'Bearer ' + (localStorage.getItem('vuon_token') || '') }
                });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const data = await res.json();

                // Hỗ trợ cả hai format
                const orders = Array.isArray(data) ? data : (data.orders || data.Orders || data.items || data.Items || []);

                if (orders.length === 0) {
                    tbody.innerHTML = '<tr class="loading-row"><td colspan="5">Chưa có đơn hàng nào.</td></tr>';
                    return;
                }

                tbody.innerHTML = orders.slice(0, 10).map(o => {
                    const code = o.orderCode || o.OrderCode || o.id || o.Id || 'N/A';
                    const customer = o.receiverName || o.ReceiverName || o.customerName || o.CustomerName || 'Khách vãng lai';
                    const total = o.totalAmount ?? o.TotalAmount ?? o.total ?? o.Total ?? 0;
                    const status = o.status || o.Status || 'pending';
                    const date = o.createdAt || o.CreatedAt || o.orderDate || o.OrderDate || '';
                    const dateStr = date ? new Date(date).toLocaleDateString('vi-VN') : '—';
                    return `<tr>
                        <td style="font-weight:600;color:#2563eb;">#${code}</td>
                        <td>${customer}</td>
                        <td style="font-weight:600;">${fmt(total)}</td>
                        <td>${orderBadge(status)}</td>
                        <td style="color:#6b7280;">${dateStr}</td>
                    </tr>`;
                }).join('');
            } catch (e) {
                console.error('Lỗi tải đơn hàng:', e);
                tbody.innerHTML = `<tr class="loading-row"><td colspan="5" style="color:#ef4444;">Lỗi tải đơn hàng: ${e.message}</td></tr>`;
            }
        }

        // Khởi động trang
        async function initPage() {
            document.getElementById('dash-date').textContent =
                new Date().toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

            // Load song song để nhanh hơn
            await Promise.all([loadStats(), loadProducts(), loadOrders()]);
        }

        initPage();
    </script>
}
