@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <style>
        .stat-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:1rem; margin-bottom:1.5rem; }
        .stat-card { background:#fff; border-radius:.75rem; padding:1.25rem; box-shadow:0 1px 4px rgba(0,0,0,.07); }
        .stat-value { font-size:1.75rem; font-weight:800; margin:.25rem 0; }
        .stat-change { font-size:.75rem; }
        .chart-card { background:#fff; border-radius:.75rem; padding:1.5rem; box-shadow:0 1px 4px rgba(0,0,0,.07); }
        .data-table { width:100%; border-collapse:collapse; }
        .data-table th { text-align:left; padding:.75rem 1rem; background:#f9fafb; font-size:.8rem; font-weight:600; color:#6b7280; border-bottom:1px solid #e5e7eb; }
        .data-table td { padding:.75rem 1rem; border-bottom:1px solid #f9fafb; font-size:.875rem; }
        @@media(max-width:768px){ .main-panel{ padding:1rem; } }
    </style>
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
  <div>
    <h1 style="font-size:1.5rem;font-weight:800;">Dashboard</h1>
    <p style="color:#6b7280;font-size:.875rem;">Tổng quan hoạt động kinh doanh thực tế</p>
  </div>
  <div style="font-size:.875rem;color:#6b7280;" id="dash-date"></div>
</div>

<!-- Stats -->
<div class="stat-grid">
  <div class="stat-card">
    <p style="font-size:.8rem;color:#6b7280;">Doanh thu hôm nay</p>
    <div class="stat-value" style="color:#10b981;" id="stat-today-revenue">0đ</div>
    <p class="stat-change" style="color:#6b7280;">Thực thu trong ngày</p>
  </div>
  <div class="stat-card">
    <p style="font-size:.8rem;color:#6b7280;">Doanh thu tháng này</p>
    <div class="stat-value" style="color:#059669;" id="stat-month-revenue">0đ</div>
    <p class="stat-change" style="color:#6b7280;">Tích lũy từ đầu tháng</p>
  </div>
  <div class="stat-card">
    <p style="font-size:.8rem;color:#6b7280;">Lượng khách hàng</p>
    <div class="stat-value" style="color:#8b5cf6;" id="stat-customer-count">0</div>
    <p class="stat-change" style="color:#6b7280;">Tài khoản khách hàng</p>
  </div>
  <div class="stat-card">
    <p style="font-size:.8rem;color:#6b7280;">Đơn đặt thành công</p>
    <div class="stat-value" style="color:#2563eb;" id="stat-orders-count">0</div>
    <p class="stat-change" style="color:#6b7280;">Đơn đã thanh toán/COD hợp lệ</p>
  </div>
</div>

<!-- Charts row -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:1rem;margin-bottom:1.5rem;">
  <div class="chart-card">
    <h3 style="font-weight:700;margin-bottom:1rem;">Doanh thu 7 ngày qua</h3>
    <canvas id="revenue-chart" height="200"></canvas>
  </div>
  <div class="chart-card">
    <h3 style="font-weight:700;margin-bottom:1rem;">Danh mục sản phẩm</h3>
    <canvas id="cat-chart" height="200"></canvas>
  </div>
</div>

<!-- Recent orders -->
<div class="chart-card">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
    <h3 style="font-weight:700;">Đơn hàng gần đây</h3>
    <a href="orders" style="font-size:.8rem;color:#2563eb;text-decoration:none;">Xem tất cả &rarr;</a>
  </div>
  <div style="overflow-x:auto;">
    <table class="data-table" id="orders-table"></table>
  </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        let productsList = [];
        let categoriesList = [];

        async function loadStats() {
          try {
            const stats = await API.getDashboardStats();
            document.getElementById('stat-today-revenue').textContent = fmt(stats.todayRevenue || 0);
            document.getElementById('stat-month-revenue').textContent = fmt(stats.monthRevenue || 0);
            document.getElementById('stat-customer-count').textContent = stats.customerCount || 0;
            document.getElementById('stat-orders-count').textContent = stats.successfulOrderCount || 0;
          } catch (e) {
            console.error("Lỗi khi tải thống kê dashboard:", e);
            showToast("Không thể tải thống kê thực tế", "error");
          }
        }

        async function initPage() {
          document.getElementById('dash-date').textContent = new Date().toLocaleDateString('vi-VN',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

          // Tải các thẻ thống kê thực tế
          await loadStats();

          // Revenue line chart (mô phỏng đồ thị)
          new Chart(document.getElementById('revenue-chart').getContext('2d'), {
            type:'line',
            data:{
              labels:['T2','T3','T4','T5','T6','T7','CN'],
              datasets:[{
                label:'Doanh thu (nghìn đồng)',
                data:[1200,980,1500,1800,1350,2200,1700],
                borderColor:'#16a34a', backgroundColor:'rgba(22,163,74,.08)', fill:true, tension:.4
              }]
            },
            options:{ plugins:{legend:{display:false}}, scales:{ y:{beginAtZero:true} } }
          });

          // Tải dữ liệu vẽ biểu đồ tròn theo danh mục
          try {
            categoriesList = await API.getCategories();
            productsList = await API.getProducts({ pageSize: 100 });
            
            const catCounts = {};
            productsList.forEach(p => {
              const catName = p.categoryName || 'Khác';
              catCounts[catName] = (catCounts[catName] || 0) + 1;
            });

            new Chart(document.getElementById('cat-chart').getContext('2d'), {
              type:'doughnut',
              data:{
                labels:Object.keys(catCounts),
                datasets:[{ data:Object.values(catCounts), backgroundColor:['#16a34a','#f59e0b','#8b5cf6','#2563eb','#ec4899','#14b8a6'] }]
              },
              options:{ plugins:{ legend:{ position:'bottom', labels:{ boxWidth:12, font:{size:11} } } }
            });
          } catch (e) {
            console.error("Lỗi khi dựng biểu đồ danh mục:", e);
          }

          // Tải danh sách đơn hàng gần đây từ API
          try {
            const ordersResponse = await API.getOrders({ pageSize: 5 });
            const recentOrders = ordersResponse.orders || [];

            document.getElementById('orders-table').innerHTML = `
              <thead><tr>
                <th>Mã đơn</th><th>Khách hàng</th><th>Sản phẩm</th><th>Tổng tiền</th><th>Trạng thái</th><th>Hành động</th>
              </tr></thead>
              <tbody>${recentOrders.length === 0 ? '<tr><td colspan="6" style="text-align:center;color:#6b7280;padding:2rem;">Chưa có đơn hàng nào thực tế.</td></tr>' : recentOrders.map(o => `
                <tr>
                  <td style="font-weight:600;color:#2563eb;">#${o.orderCode}</td>
                  <td>${o.receiverName || 'Khách vãng lai'}</td>
                  <td style="color:#6b7280;">${o.items?.length || 1} sản phẩm</td>
                  <td style="font-weight:600;">${fmt(o.totalAmount)}</td>
                  <td>${statusLabel(o.status.toLowerCase())}</td>
                  <td><a href="order-detail?id=${o.orderId}" style="font-size:.8rem;color:#2563eb;text-decoration:none;">Chi tiết</a></td>
                </tr>`).join('')}
              </tbody>`;
          } catch (e) {
            console.error("Lỗi khi tải đơn hàng gần đây:", e);
            document.getElementById('orders-table').innerHTML = '<tr><td colspan="6" style="text-align:center;color:#ef4444;padding:2rem;">Lỗi tải đơn hàng gần đây.</td></tr>';
          }
        }

        initPage();
    </script>
}
