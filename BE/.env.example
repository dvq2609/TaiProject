# =============================================
# VƯƠN - Template .env (COPY file này thành .env và điền giá trị thật)
# KHÔNG commit file .env thật lên git!
# =============================================

# ── App ──────────────────────────────────────
# URL của Frontend (đổi thành domain thật khi deploy)
App__FrontendBaseUrl=http://localhost:5254
# Danh sách origin được phép gọi API (CORS), phân cách bằng dấu phẩy
App__AllowedOrigins__0=http://localhost:5254

# ── JWT ──────────────────────────────────────
Jwt__Key=YOUR_VERY_LONG_RANDOM_SECRET_KEY_HERE_AT_LEAST_32_CHARS

# ── Google OAuth ──────────────────────────────
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
Authentication__Google__ClientSecret=YOUR_GOOGLE_CLIENT_SECRET

# ── Email (SMTP) ─────────────────────────────
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__Username=your-email@gmail.com
Email__Password=your-gmail-app-password
Email__FromEmail=your-from-email@gmail.com
Email__FromName=Vươn

# ── PayOS ────────────────────────────────────
PayOS__ClientId=YOUR_PAYOS_CLIENT_ID
PayOS__ApiKey=YOUR_PAYOS_API_KEY
PayOS__ChecksumKey=YOUR_PAYOS_CHECKSUM_KEY
# URL redirect sau khi thanh toán (đổi thành domain thật khi deploy)
PayOS__ReturnUrl=http://localhost:5254/payment-success
PayOS__CancelUrl=http://localhost:5254/payment-cancel

# ── AI Chat ──────────────────────────────────
AiChat__ApiKey=YOUR_GEMINI_OR_OPENAI_API_KEY
AiChat__BaseUrl=https://generativelanguage.googleapis.com
AiChat__Model=gemini-2.5-flash
